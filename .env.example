# Base URL for Confluence (no trailing slash). REST: /wiki/rest/api (Cloud) or /rest/api (many DC); auto-probed if unset.
# Cloud example: https://your-company.atlassian.net
# Separate wiki subdomain: https://wiki.your-company.com
ATLASSIAN_SITE=https://your-company.atlassian.net

# Jira base URL when it differs from Confluence (separate subdomain, different host, or /jira context).
# Defaults to ATLASSIAN_SITE if unset.
# Same host, Jira under /jira: https://intranet.example.com/jira
# Separate jira subdomain: https://jira.your-company.com
# JIRA_SITE=https://jira.your-company.com

# Atlassian account email + API token (https://id.atlassian.com/manage-profile/security/api-tokens)
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=

# Output directory (relative to the current working directory when you run the CLI)
OUTPUT_DIR=output

# Optional extra JQL combined with OR against the auto-generated query
# Example: project = MYPROJ AND labels = context
EXTRA_JQL=

# If 1, only RAW_JQL is used (no auto-generated user-centric JQL)
USE_RAW_JQL_ONLY=0

# Raw JQL when USE_RAW_JQL_ONLY=1
RAW_JQL=

# Confluence: leave empty to sync every space you can access (can be slow)
# Comma-separated keys, e.g. DEV,TEAM
CONFLUENCE_SPACE_KEYS=

# Force REST path if auto-probe fails: /rest/api or /wiki/rest/api
# CONFLUENCE_REST_PREFIX=/rest/api

# Max pages to fetch per space (safety cap)
CONFLUENCE_MAX_PAGES_PER_SPACE=500

# Jira: max issues per search request (Atlassian caps this at 100)
JIRA_PAGE_SIZE=100

# Force Jira REST version: 2 (Server/DC) or 3 (Cloud). Leave unset to auto-detect.
# JIRA_REST_API_VERSION=2

# TLS: set to 0 only if your Jira/Confluence uses a self-signed or private CA cert (insecure).
# Applies to both Python (httpx) and Node (undici fetch dispatcher).
HTTPX_VERIFY_SSL=1
